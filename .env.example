# Deriv API Configuration
DERIV_APP_ID=your_app_id_here
DERIV_API_TOKEN=your_api_token_here
DERIV_API_URL=https://ws.derivws.com/websockets/v3

# Trading Configuration
RISK_PER_TRADE=0.5
MAX_DAILY_LOSSES=3
MAX_DRAWDOWN_PERCENT=5.0
MIN_TRADE_SCORE=80
MIN_RR_RATIO=3.0

# Market Configuration
PRIMARY_TIMEFRAME=15
CONFIRMATION_TIMEFRAME=5
EXECUTION_TIMEFRAME=1
DEFAULT_SYMBOLS=R_100,R_50,R_10

# Alerts & Notifications
ALERT_ENABLED=true
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
EMAIL_ALERTS=true
EMAIL_ADDRESS=your_email@example.com

# Database
DB_PATH=./data/trades.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# Dashboard
DASHBOARD_PORT=8050
DASHBOARD_HOST=127.0.0.1
